# Docker Compose reads this file via `env_file: .env`.
# Copy to `.env` and fill in secrets/URLs as needed.

# Database / cache (used by docker-compose.yml to build DATABASE_URL / REDIS_URL)
# Apple Silicon note: the Timescale HA image is often `linux/amd64` only; set this to silence platform warnings.
POSTGRES_PLATFORM=linux/amd64
POSTGRES_PASSWORD=change_this_strong_password
REDIS_PASSWORD=change_this_redis_password

# API auth (backend + frontend)
CHATBI_API_KEY=change_me

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL_A=gpt-4o-mini
OPENAI_CHAT_MODEL_B=gpt-5.2
OPENAI_SQL_REFINER_MODEL=gpt-5.2
OPENAI_SQL_TIMEOUT_SECONDS=20

# LangSmith tracing (optional)
# LANGSMITH_API_KEY is your Personal Access Token (lsv2_pt_...) from
# https://smith.langchain.com/settings — workspace is implicit from the key.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=seon-history
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Optional import sources for `python backend/cli.py sync`.
# Fill in real source credentials in your local .env — never commit them here.
SOURCE_POSTGRES_URL=
SOURCE_POSTGRES_TABLE=home_alarms
SOURCE_MONGO_URL=mongodb://USER:PASSWORD@HOST:27017/DB?authSource=admin
SOURCE_MONGO_DB=history_development
SOURCE_MONGO_COLLECTION=historical_alarms
